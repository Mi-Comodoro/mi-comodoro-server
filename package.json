    "url": "git+https://github.com/migueljalvarez/nest-template.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/migueljalvarez/nest-template/issues"
  },
  "homepage": "https://github.com/migueljalvarez/nest-template#readme",
  "dependencies": {
    "@nestjs/axios": "^4.0.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.16",
    "@nestjs/event-emitter": "^3.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "11.0.0",
    "argon2": "^0.44.0",
    "axios": "^1.13.6",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "date-fns": "^4.1.0",
    "decimal.js": "^10.6.0",
    "fast-xml-parser": "^5.5.5",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "joi": "18.0.2",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "8.17.2",
    "typeorm": "0.3.28"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/date-fns": "^2.5.3",
    "@types/express": "5.0.6",
    "@types/node": "^25.5.0",
    "@types/passport-jwt": "^4.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.7.4",
    "ts-node": "^10.9.2",
    "tsc-alias": "1.8.16",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "8.48.1"
  },
  "overrides": {
    "@nestjs/common": {
      "file-type": "^16.5.4"
    },
    "file-type": "^16.5.4",
    "@tootallnate/once": "2.0.0",
    "http-proxy-agent": "7.0.2"
  },
  "engines": {
    "node": "22.11.x",
    "npm": "11.5.2"
  },
  "lint-staged": {
    "*.{ts,js}": [
