  "description": "Finanzas personales y Hogar",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write src/**/*.ts",
    "build": "nest build && tsc-alias",
    "prepare": "husky",
    "seed:categories": "ts-node -r tsconfig-paths/register src/scripts/seed-categories.ts"
  },
